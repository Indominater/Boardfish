{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Boardfish",
  "version": "0.3.3",
  "identifier": "com.boardfish.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Boardfish",
        "width": 1280,
        "height": 800,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/Icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["bf"],
        "name": "Boardfish Board",
        "description": "Boardfish Board",
        "mimeType": "application/x-boardfish",
        "icon": "icons/Icon.icns",
        "role": "Editor"
      }
    ],
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
